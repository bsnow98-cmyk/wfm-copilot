# Copy this file to .env and adjust as needed.
# Do NOT commit .env (it's in .gitignore).

# --- Postgres ---
POSTGRES_USER=wfm
POSTGRES_PASSWORD=wfm_dev_password
POSTGRES_DB=wfm_copilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Anthropic (Phase 6 — required, app refuses to start without it) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Auth gate (Phase 6) ---
# Single shared password gate. Unset = open (dev mode). Set = required for
# every route except /health, /docs, /openapi.json, /redoc.
WFM_DEMO_PASSWORD=

# --- Tool timeouts (Phase 6 GA gap #3) ---
# Hard ceiling on dispatch wall-clock per tool call. 30s matches the design.
TOOL_TIMEOUT_SECONDS=30
